
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>과제 평가 보드 (참가자용 / AX, Light Gray - Full Width)</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    /* -----------------------------
       Light Gray Theme Variables
       ----------------------------- */
    :root{
      --bg:#f5f6f8;          /* 페이지 배경 */
      --text:#1f2937;        /* 본문 텍스트(짙은 회색) */
      --textSub:#4b5563;     /* 보조 텍스트 */
      --panel:#ffffff;       /* 카드/패널 배경 */
      --border:#e5e7eb;      /* 테두리 */
      --lane:#fafafa;        /* Lane 배경 */
      --laneBorder:#e5e7eb;  /* Lane 테두리 */
      --card:#ffffff;        /* Task 카드 배경 */
      --cardBorder:#e2e8f0;  /* Task 카드 테두리 */
      --accent:#3b82f6;      /* 포커스/강조(블루톤) */
      --chip:#6b7280;        /* 카운트 배지 글자색 */

      --btnBg:#ffffff;
      --btnBorder:#e5e7eb;
      --btnText:#111827;
      --btnHover:#f3f4f6;

      --ok:#059669;    /* 제출성공, 초록 */
      --warn:#d97706;  /* 경고, 주황 */
      --err:#dc2626;   /* 오류, 빨강 */
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial,
                   Apple SD Gothic Neo, Malgun Gothic, "맑은 고딕", Noto Sans KR, sans-serif;
      background:var(--bg);
      color:var(--text);
    }

    header{
      padding:20px;
      border-bottom:1px solid var(--border);
      background:linear-gradient(180deg, #ffffff 0%, #f7f7f9 100%);
    }
    h1{margin:0 0 8px; font-size:20px; color:#111827}
    .sub{color:var(--textSub); font-size:13px}

    /* ✅ Full width */
    .wrap{ padding:16px }

    .form{
      display:grid; gap:10px; grid-template-columns: 1fr; margin:12px 0 16px
    }
    @media (min-width:720px){
      .form{ grid-template-columns: 1fr 1fr auto }
    }
    .input{display:flex; flex-direction:column; gap:6px}
    label{font-size:12px; color:#374151}
    input[type="text"]{
      background:#ffffff; color:#111827;
      border:1px solid var(--btnBorder);
      border-radius:10px; padding:10px; font-size:13px;
    }

    .btn{
      background:var(--btnBg); border:1px solid var(--btnBorder); color:var(--btnText);
      padding:10px 14px; border-radius:10px; cursor:pointer; font-size:14px; align-self:end; height:40px;
      transition: background .12s ease;
    }
    .btn:hover{ background:var(--btnHover) }
    .btn:disabled{ opacity:0.6; cursor:not-allowed }

    .boards{ display:grid; gap:16px }
    @media (min-width:900px){ .boards{ grid-template-columns: 1fr 1fr; } } /* 살짝 빠르게 2열 전환 */

    .board{
      background:var(--panel); border:1px solid var(--border); border-radius:14px; padding:12px
    }
    .board h2{ margin:4px 0 12px; font-size:16px; color:#111827 }

    .lanes{ display:grid; gap:10px; grid-template-columns: 1fr }
    @media (min-width:680px){ .lanes{ grid-template-columns: repeat(2, 1fr); } }
    @media (min-width:1000px){ .lanes{ grid-template-columns: repeat(4, 1fr); } } /* ✅ 4열 전환 당김 */

    .lane{
      background:var(--lane);
      border:1px dashed var(--laneBorder);
      border-radius:12px; min-height:120px; padding:8px;
      display:flex; flex-direction:column; gap:8px
    }
    .lane.drag-over{ outline:2px solid var(--accent); outline-offset:-2px; background:#ffffff }

    .lane-head{
      display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:4px
    }
    .lane-title{ font-size:13px; color:#374151; font-weight:600 }
    .chip{
      font-size:11px; color:var(--chip);
      background:#f3f4f6; border:1px solid var(--laneBorder);
      padding:2px 6px; border-radius:999px
    }
    .cards{ display:flex; flex-direction:column; gap:8px }

    .card{
      background:var(--card); border:1px solid var(--cardBorder);
      border-radius:10px; padding:8px;
      display:flex; justify-content:space-between; align-items:center; gap:8px; cursor:grab
    }
    .card:active{ cursor:grabbing }
    .card-id{ font-size:11px; color:#6b7280 }
    .card-title{ font-size:13px; color:#111827 }

    .note{ padding:8px 0; color:#6b7280; font-size:12px }
    .ok{ color:var(--ok) } .warn{ color:var(--warn) } .err{ color:var(--err) }
  </style>
</head>
<body>
  <header>
    <h1>과제 평가 보드 — 참가자용 (AX)</h1>
    <div class="sub">팀/이름 입력 → 드래그 분류 → <strong>제출</strong>. (과제명은 관리자 고정)</div>
  </header>

  <div class="wrap">
    <!-- 입력 폼 -->
    <div class="form">
      <div class="input">
        <label for="team">팀</label>
        <input id="team" type="text" placeholder="예: 마케팅팀" required />
      </div>
      <div class="input">
        <label for="name">이름</label>
        <input id="name" type="text" placeholder="예: 이정민" required />
      </div>
      <button id="submitBtn" class="btn">제출</button>
    </div>
    <div id="msg" class="note">※ 새로고침 시 분류 내용은 초기화됩니다. (저장 없음)</div>

    <!-- 보드 -->
    <div class="boards">
      <div class="board">
        <h2>Biz Impact</h2>
        <div class="lanes" data-axis="impact">
          <div class="lane" data-axis="impact" data-level="Unassigned">
            <div class="lane-head"><span class="lane-title">Unassigned</span><span class="chip" id="count-impact-Unassigned">0</span></div>
            <div class="cards" id="lane-impact-Unassigned"></div>
          </div>
          <div class="lane" data-axis="impact" data-level="High">
            <div class="lane-head"><span class="lane-title">High</span><span class="chip" id="count-impact-High">0</span></div>
            <div class="cards" id="lane-impact-High"></div>
          </div>
          <div class="lane" data-axis="impact" data-level="Medium">
            <div class="lane-head"><span class="lane-title">Medium</span><span class="chip" id="count-impact-Medium">0</span></div>
            <div class="cards" id="lane-impact-Medium"></div>
          </div>
          <div class="lane" data-axis="impact" data-level="Low">
            <div class="lane-head"><span class="lane-title">Low</span><span class="chip" id="count-impact-Low">0</span></div>
            <div class="cards" id="lane-impact-Low"></div>
          </div>
        </div>
      </div>

      <div class="board">
        <h2>Feasibility</h2>
        <div class="lanes" data-axis="feasibility">
          <div class="lane" data-axis="feasibility" data-level="Unassigned">
            <div class="lane-head"><span class="lane-title">Unassigned</span><span class="chip" id="count-feasibility-Unassigned">0</span></div>
            <div class="cards" id="lane-feasibility-Unassigned"></div>
          </div>
          <div class="lane" data-axis="feasibility" data-level="High">
            <div class="lane-head"><span class="lane-title">High</span><span class="chip" id="count-feasibility-High">0</span></div>
            <div class="cards" id="lane-feasibility-High"></div>
          </div>
          <div class="lane" data-axis="feasibility" data-level="Medium">
            <div class="lane-head"><span class="lane-title">Medium</span><span class="chip" id="count-feasibility-Medium">0</span></div>
            <div class="cards" id="lane-feasibility-Medium"></div>
          </div>
          <div class="lane" data-axis="feasibility" data-level="Low">
            <div class="lane-head"><span class="lane-title">Low</span><span class="chip" id="count-feasibility-Low">0</span></div>
            <div class="cards" id="lane-feasibility-Low"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="note">ⓘ 과제명은 관리자에 의해 고정되었습니다. 참가자는 변경할 수 없습니다.</div>
  </div>

  <script>
    /* =========================
       설정: Power Automate Webhook
       ========================= */
    const WEBHOOK_URL = "https://default513294a03e2041b2a9706d30bf1546.fa.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/0ca682a1b66f449dbb16643c59ced472/triggers/manual/paths/invoke?api-version=1";

    /* =========================
       고정 과제명 (관리자 제공 36개) + AX ID
       ========================= */
    const TITLES = [
      "A1_AI기반 마케팅 효과 탐지/측정 자동화 및 MMM(성과 분석)",
      "A2_AI 생성 기반 마케팅 기획안 자동 생성·추천 엔진",
      "A3_가상고객 기반 마케팅 시나리오 시뮬레이션 AI",
      "A4_투숙객/예약 정보 연계 기반 객실 정비 우선순위 및 스케줄링 최적화",
      "A5_실시간 보안 모니터링 및 이상징후 탐지 인텔리전스",
      "A6_ML 기반 매출 이상 탐지 및 원인 파악 인사이트 도출",
      "B1_운반/청소 로보틱스 PoC",
      "B2_위험/고난도 작업 수행 및 비전AI 품질 검사 PoC",
      "C1_신규호텔개발 위한 AI기반 Market Intelligence",
      "C2_신규호텔개발 AI 타당성 분석 및 시뮬레이션",
      "C3_AI 기반 상품기획 리서치 인사이트 발굴",
      "C4_AI 기반 멤버십 경쟁사 비교·분석 리서치",
      "C5_멤버십 정책·약관 분석 Copilot",
      "C6_B2B 수요 발굴 및 고가치 타겟 고객사 선정 인텔리전스",
      "D1_AI/AR 기반 글로벌 및 현장 교육·학습 지원",
      "D2_리스크/컴플라이언스 검토 위한 Archive AI 설계",
      "D3_법무/계약 조항 식별 및 현지화 Copilot",
      "E1_ML 기반 고객문의 분류 및 응답 매핑 자동화",
      "E2_실시간 AI 상담 가이드 (자막, 응대스크립트, 다국어, 가드레일)",
      "F1_AI 기반 터치포인트(디바이스) 확장 및 고도화",
      "F2_AI 컨시어지 (응답형-개인화/실행형-자율형 순차 고도화)",
      "G1_AI 분석 기반 고객 세그먼테이션 및 맞춤형 오퍼 생성",
      "G2_고객 E2E 여정 기반 초개인화 호텔 경험 제공 AI",
      "G3_AEO·GEO 기반 호텔 검색·추천·지식 경험 최적화",
      "H1_설비 검침·공조 설비 자율 제어·에너지 최적화 AI (비용 배부 자동화 포함)",
      "H2_공사 예가 산출 자동화 AI",
      "H3_ITSM/보안포털 예외·티켓 자동 처리 AI",
      "H4_전표 생성 및 처리 자동화",
      "H5_ML 기반 소모품 수요예측 및 발주 자동화",
      "H6_고객 안내용 컨텐츠 AI생성 및 품의 생성 자동화 (연회/레스토랑/부대시설 등)",
      "H7_프로퍼티별 이슈/이벤트 요약 및 보도자료 주제 추천",
      "H8_상품/서비스 문의 요약 기반 견적 생성 자동화 (B2B 영업 대상)",
      "H9_주요 경쟁사 및 자사 보도자료 기반 보고문서 생성 AI",
      "H10_부정 이슈 관련 내/외부 조치 업무 제안(문서초안 자동 생성)",
      "H11_체크리스트 및 업무 추적관리 워크플로우",
      "H12_개인정보보호 인식 제고용 뉴스레터 AI 콘텐츠 제작"
    ];

    // 상태
    let state = {
      tasks: [],
      assign: {
        impact: { Unassigned: [], High: [], Medium: [], Low: [] },
        feasibility: { Unassigned: [], High: [], Medium: [], Low: [] },
      }
    };

    // 과제 빌드
    function buildTasks(){
      const arr = [];
      for(let i=1;i<=36;i++){
        const id = "AX" + String(i).padStart(2,"0");
        const title = (TITLES[i-1] && String(TITLES[i-1]).trim()) ? String(TITLES[i-1]).trim() : `과제 ${String(i).padStart(2,"0")}`;
        arr.push({ id, title });
      }
      return arr;
    }

    // 초기화
    function init(){
      state.tasks = buildTasks();
      const ids = state.tasks.map(t=>t.id);
      state.assign.impact.Unassigned = [...ids];
      state.assign.feasibility.Unassigned = [...ids];
      render();
      wireDnD();
      document.getElementById("submitBtn").addEventListener("click", handleSubmit);
    }

    function render(){
      ["impact","feasibility"].forEach(axis=>{
        ["Unassigned","High","Medium","Low"].forEach(level=>{
          const container = document.getElementById(`lane-${axis}-${level}`);
          container.innerHTML = "";
          state.assign[axis][level].forEach(taskId=>{
            const task = state.tasks.find(t => t.id === taskId);
            if(!task) return;
            const el = document.createElement("div");
            el.className = "card"; el.setAttribute("draggable","true");
            el.dataset.taskId = task.id; el.dataset.axis = axis; el.dataset.level = level;
            el.innerHTML = `<div><div class="card-id">${task.id}</div><div class="card-title">${escapeHtml(task.title)}</div></div>`;
            container.appendChild(el);
          });
        });
      });
      updateCounts();
    }

    function wireDnD(){
      document.querySelectorAll(".lane").forEach(lane=>{
        lane.addEventListener("dragover", (e)=>{ e.preventDefault(); lane.classList.add("drag-over"); });
        lane.addEventListener("dragleave", ()=> lane.classList.remove("drag-over"));
        lane.addEventListener("drop", (e)=>{
          e.preventDefault(); lane.classList.remove("drag-over");
          const card = document.querySelector(".card[draggable='true'][data-dragging='1']");
          if(!card) return;
          const taskId = card.dataset.taskId;
          const axis = lane.dataset.axis;
          const level = lane.dataset.level;
          moveTask(axis, taskId, level);
        });
      });

      document.addEventListener("dragstart", (e)=>{
        const el = e.target.closest(".card");
        if(el){ el.dataset.dragging = "1"; e.dataTransfer.effectAllowed="move"; }
      });
      document.addEventListener("dragend", (e)=>{
        const el = e.target.closest(".card");
        if(el){ delete el.dataset.dragging; }
      });
    }

    function moveTask(axis, taskId, level){
      ["Unassigned","High","Medium","Low"].forEach(lvl=>{
        state.assign[axis][lvl] = state.assign[axis][lvl].filter(id => id !== taskId);
      });
      state.assign[axis][level].push(taskId);
      render();
    }

    function updateCounts(){
      ["impact","feasibility"].forEach(axis=>{
        ["Unassigned","High","Medium","Low"].forEach(level=>{
          const n = state.assign[axis][level].length;
          const badge = document.getElementById(`count-${axis}-${level}`);
          if(badge) badge.textContent = n;
        });
      });
    }

    function escapeHtml(s){
      return String(s)
        .replace(/&/g,"&amp;")
        .replace(/</g,"&lt;")
        .replace(/>/g,"&gt;");
    }

    // 제출 (High=5, Medium=3, Low=1, Unassigned=0)
    const scoreMap = { High:5, Medium:3, Low:1, Unassigned:0 };
    function getLevel(axis, taskId){
      for(const lv of ["High","Medium","Low","Unassigned"]){
        if(state.assign[axis][lv].includes(taskId)) return lv;
      }
      return "Unassigned";
    }
    function genId(){ return "RID-"+Math.random().toString(36).slice(2,10)+"-"+Date.now().toString(36); }

    function computeRows(team, name){
      const timestamp = new Date().toISOString();
      const reqId = genId();
      return state.tasks.map(t=>{
        const impactLevel = getLevel("impact", t.id);
        const feasLevel = getLevel("feasibility", t.id);
        const impactScore = scoreMap[impactLevel] ?? 0;
        const feasibilityScore = scoreMap[feasLevel] ?? 0;
        return {
          timestamp, team, name, requestId: reqId,
          taskId: t.id, taskTitle: t.title,
          impactLevel, impactScore,
          feasibilityLevel: feasLevel, feasibilityScore,
          totalScore: impactScore + feasibilityScore
        };
      });
    }

    function handleSubmit(){
      const team = document.getElementById("team").value.trim();
      const name = document.getElementById("name").value.trim();
      const btn = document.getElementById("submitBtn");
      const msg = document.getElementById("msg");

      if(!team || !name){ msg.innerHTML = '<span class="err">팀과 이름을 입력해 주세요.</span>'; return; }
      if(!WEBHOOK_URL || WEBHOOK_URL.startsWith("PASTE_")){
        msg.innerHTML = '<span class="err">제출 URL이 설정되지 않았습니다. 관리자에게 문의하세요.</span>'; return;
      }

      const payload = {
        meta: { team, name, submittedAt: new Date().toISOString(), userAgent: navigator.userAgent, version: "v1-AX-readonly" },
        rows: computeRows(team, name)
      };

      btn.disabled = true; btn.textContent = "제출 중...";
      msg.innerHTML = '<span class="note">제출 중입니다...</span>';

      fetch(WEBHOOK_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      })
      .then(async (res)=>{
        if(!res.ok){ const t = await res.text().catch(()=> ""); throw new Error("HTTP "+res.status+" "+t); }
        msg.innerHTML = '<span class="ok">제출 완료! 감사합니다.</span>';
        btn.textContent = "제출 완료";
      })
      .catch(err=>{
        console.error(err);
        msg.innerHTML = '<span class="err">제출 실패. 네트워크/권한 확인 후 다시 시도하세요.</span>';
        btn.disabled = false; btn.textContent = "제출";
      });
    }

    // 부트
    init();
  </script>
</body>
</html>
